#: l10n/source/edge.xml:2342 l10n/source/edge.xml:2838
msgid "day2 helm chart upgrade example 1"
msgstr "day2 helmチャートアップグレード例1"

#. type: Content of: <book><part><chapter><section><section><section><section><section><orderedlist><listitem><orderedlist><listitem><figure>
#: l10n/source/edge.xml:2343 l10n/source/edge.xml:2351
